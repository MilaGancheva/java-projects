<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToHeight="true" fitToWidth="true" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sudokusolver.sudokuparallel.SudokuController">
    <content>
        <VBox alignment="TOP_CENTER" spacing="10.0" style="-fx-background-color: #f4f4f4;">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>

            <Label text="Parallel Sudoku Solver">
                <font>
                    <Font name="System Bold" size="26.0" />
                </font>
            </Label>

            <HBox alignment="CENTER" spacing="20.0">
                <HBox alignment="CENTER" spacing="8.0">
                    <Label text="Sudoku Size:" />
                    <ChoiceBox fx:id="modeChoiceBox" prefWidth="150.0" />
                </HBox>

                <HBox alignment="CENTER" spacing="8.0">
                    <Label text="Algorithm:" />
                    <ChoiceBox fx:id="algoChoiceBox" prefWidth="140.0" />
                </HBox>
            </HBox>

            <StackPane VBox.vgrow="ALWAYS">
                <GridPane fx:id="sudokuGrid" alignment="CENTER" hgap="1.0" vgap="1.0"
                          style="-fx-background-color: #7f8c8d; -fx-padding: 2; -fx-background-radius: 2;">
                </GridPane>
            </StackPane>

            <Separator prefWidth="200.0" />

            <HBox alignment="CENTER" spacing="15.0">
                <Button fx:id="solveBtn" onAction="#handleSolve" prefWidth="110.0"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Solve" />

                <Button fx:id="clearButton" onAction="#handleClear" prefWidth="110.0"
                        style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold;" text="Clear" />

                <Button fx:id="generateBtn" onAction="#handleGenerate" prefWidth="110.0"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="Generate" />
            </HBox>

            <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 10; -fx-border-color: #ddd;">
                <Label fx:id="statusLabel" text="Enter numbers and press Solve" textFill="#555">
                    <font>
                        <Font name="System Italic" size="13.0" />
                    </font>
                </Label>

                <HBox alignment="CENTER" spacing="30.0">
                    <Label fx:id="timerLabel" text="Time: 0.0000 s" textFill="#e67e22">
                        <font>
                            <Font name="System Bold" size="15.0" />
                        </font>
                    </Label>

                    <Label fx:id="backtrackLabel" text="Backtracks: 0" textFill="#2980b9">
                        <font>
                            <Font name="System Bold" size="15.0" />
                        </font>
                    </Label>

                    <Label fx:id="solutionsLabel" text="Solutions: 0" textFill="#27ae60">
                        <font>
                            <Font name="System Bold" size="15.0" />
                        </font>
                    </Label>
                </HBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
